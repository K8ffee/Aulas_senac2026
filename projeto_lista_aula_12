produtos = []
while True:

    print("--- Loja de eletrônicos ---")
    print("1 - Cadastrar produto ---")
    print("2 - Listar produtos ---")
    print("3 - Vender produtos---")
    print("4 - Mostrar estoque---")
    print("5 - Sair")

    opcao = input("Selecione uma opção: ")

    if opcao == "1":
        nome_produto = input("Nome do produto: ")
        valor = float(input("Preço do produto: "))
        estoque = int(input("Quantidade em estoque: "))
        produtos.append([nome_produto,valor,estoque])
        print(f"{nome_produto} cadastrado com sucesso!")
    elif opcao == "2":
        print("---Produtos cadastrados---")
        for p in produtos:
            print(f"Produto: {p[0]} | preço R${p[1]} | Estoque: {p[2]}")
    elif opcao == "3":
        nome_produto = input("Digite o nome do produto a venda: ")
        encontrado = False
        for p in produtos:
            if p[0]== nome_produto:
                encontrado = True
                if p[2]> 0:
                 p[2] -=1
                 print(f"Venda realizada {nome_produto} agora tem {p[2]} unidades disponíveis")
                else:
                    print("Produto sem estoque")
                    break
        if not encontrado:
            print("Estoque não encontrado")
    elif opcao == "4":
        total_itens = sum([p[2] for p in produtos])
        print(F"Total de itens em estoque: {total_itens}")
    elif opcao == "5":
        print("Saindo...")
        break
    else:
        print("Opção Inválida")
